# EditorConfig — https://editorconfig.org
# Top-most config file
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,mdx}]
trim_trailing_whitespace = false  # markdown soft line breaks
indent_size = 2

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.{html,css,js,ts,jsx,tsx}]
indent_size = 2

[*.{swift}]
indent_size = 4
max_line_length = 120

[*.{go}]
indent_style = tab
indent_size = 4

[Makefile]
indent_style = tab

[*.sh]
indent_size = 2
