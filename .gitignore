# =============================================================================
# JARVIS Telemetry — .gitignore
# =============================================================================

# ── Build artifacts ─────────────────────────────────────────────────────────
.build/
build/
DerivedData/
*.o
*.d
*.swp
*.swo
*.xcuserdata
*.xcworkspace/

# ── Compiled Go binary (built per-machine from mactop/) ─────────────────────
jarvis-mactop-daemon
JarvisTelemetry/Sources/JarvisTelemetry/Resources/jarvis-mactop-daemon
mactop/mactop
mactop/.git
mactop/mactop.gif
mactop/screenshota.png
mactop_backup/

# ── macOS junk ──────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Python (pipeline tooling under scripts/) ────────────────────────────────
**/.venv/
**/venv/
**/__pycache__/
*.pyc
*.pyo
*.pkl
.pytest_cache/
.coverage
htmlcov/

# ── Node / npm (none currently, future-proofing) ────────────────────────────
node_modules/
package-lock.json
package.json

# ── IDEs & editor state ─────────────────────────────────────────────────────
.vscode/
.idea/
.cursor/
.cursorrules

# ── Claude Code / agent tooling state (per-machine) ─────────────────────────
.claude/
.remember/
.superpowers/
.serena/
.context/
.filescope/
.sourcerer/
.juno_task/
.ralph-infinite.log
mcp-debug.log

# ── Logs (universal) ────────────────────────────────────────────────────────
*.log
logs/
state/
tmp/

# ── Generated media assets (regenerable via scripts/promo-video/) ───────────
*.png
*.jpeg
*.jpg
*.mp4
*.gif
promo/
scripts/promo-video/fonts/

# ── Secrets — NEVER commit ──────────────────────────────────────────────────
.env
.env.*
tests/api_keys.env
mcp.json

# ── CI workflows are managed externally for now ─────────────────────────────
.github/

# ── Per-machine docs that override repo defaults ────────────────────────────
LICENSE
CLAUDE.md